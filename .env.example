# Copy to .env and fill in. Values here are safe dev defaults / placeholders.
# NOTE: rotate any credentials that were previously committed in settings.py.

# Core
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostGIS)
POSTGRES_DB=isafepass
POSTGRES_USER=justwin
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://127.0.0.1:6379
# Set CELERY_WORKER=True (and run a worker) to send SMS asynchronously.
CELERY_WORKER=False

# CORS
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=

# Email
EMAIL_HOST=justwin.com.ng
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=info@justwin.com.ng
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=JustWin <noreply@justwin.com.ng>

# Third-party keys
GROQ_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_OAUTH_CLIENT_IDS=408333176328-dg5776ui7jl7ko6slr2b1h0kot5pu290.apps.googleusercontent.com

# OTP
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# Login lockout
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# SMS — leave as console backend for dev (codes returned as dev_otp).
# For real delivery: SMS_BACKEND=accounts.services.sms.AfricasTalkingSMSBackend
SMS_BACKEND=accounts.services.sms.ConsoleSMSBackend
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=

# iSafePass trusted backend bridge (leave empty to disable SSO endpoints)
ISAFEPASS_BASE_URL=
ISAFEPASS_SERVICE_SECRET=
ISAFEPASS_TIMEOUT_SECONDS=10

# KYC & Verification
# Private document store (kept out of the public /media/ path).
PRIVATE_MEDIA_ROOT=
# Identity provider: default is manual admin review (no-op). Swap for an
# external NIN/face-match provider class later.
KYC_IDENTITY_PROVIDER=kyc.services.providers.NoOpProvider
VERIFICATION_REMINDER_DAYS=30
# Public base URL embedded in verification QR codes.
PUBLIC_BASE_URL=http://localhost:8000
